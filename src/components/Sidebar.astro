---
import type { Props } from "@astrojs/starlight/props";

import MobileMenuFooter from "@astrojs/starlight/components/MobileMenuFooter.astro";
import SidebarSublist from "./SidebarSublist.astro";

const { sidebar } = Astro.props;
const { slug } = Astro.params;

const currentId = Astro.props.entry?.data?.sidebar?.attrs?.id;
const normalizedSlug = String(slug || "");

function hasEntryId(entries: any[], id: string): boolean {
  if (!entries?.length) return false;
  return entries.some((entry) => {
    if (entry?.attrs?.id === id) return true;
    if (entry?.entries?.length) return hasEntryId(entry.entries, id);
    return false;
  });
}

let filterSidebar = sidebar;
const fabSidebar = sidebar.filter((item: any) => hasEntryId(item?.entries || [], "fab"));

const effectiveId = currentId === "tutorial" ? "fab" : currentId;

if (effectiveId) {
  const matched = sidebar.filter((item: any) => hasEntryId(item?.entries || [], effectiveId));
  if (matched.length) {
    filterSidebar = matched;
  } else if (/(^|\/)(fab|tutorials)(\/|$)/.test(normalizedSlug) && fabSidebar.length) {
    filterSidebar = fabSidebar;
  }
} else if (/(^|\/)(fab|tutorials)(\/|$)/.test(normalizedSlug) && fabSidebar.length) {
  filterSidebar = fabSidebar;
}
---

<SidebarSublist sublist={filterSidebar} />
<div class="md:sl-hidden">
  <MobileMenuFooter {...Astro.props} />
</div>
